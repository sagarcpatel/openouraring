{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "openoura",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-06-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".svelte-kit/cloudflare",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
